{
  "name": "medusa-payment-cybersource",
  "version": "1.0.0",
  "description": "CyberSource payment provider for Medusa.js v2 with Flex Microform (PCI DSS SAQ-A)",
  "author": "Eleven",
  "license": "MIT",
  "keywords": [
    "medusa",
    "medusa-plugin",
    "medusajs",
    "payment",
    "cybersource",
    "flex-microform",
    "pci-dss",
    "ecommerce"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Eleven-Estudio/medusa-payment-cybersource"
  },
  "bugs": {
    "url": "https://github.com/Eleven-Estudio/medusa-payment-cybersource/issues"
  },
  "homepage": "https://github.com/Eleven-Estudio/medusa-payment-cybersource#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "./.medusa/server/src/index.js",
  "types": "./.medusa/server/src/index.d.ts",
  "exports": {
    ".": {
      "require": "./.medusa/server/src/index.js",
      "types": "./.medusa/server/src/index.d.ts"
    },
