  },
  "files": [
    ".medusa/server"
  ],
  "scripts": {
    "build": "npm run clean && tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf .medusa dist tsconfig.tsbuildinfo"
  },
  "peerDependencies": {
    "@medusajs/framework": ">=2.0.0"
  },
  "dependencies": {
    "cybersource-rest-client": "^0.0.61",
